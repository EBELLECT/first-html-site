  <title>My Favorite Games</title>

  <style>
    body {
      margin: 0;
      padding: 40px;
      background: #f5f5f5;
      font-family: Arial, sans-serif;
    }

    /* Container for all cards */
    .cards-container {
      display: flex;
      justify-content: center; /* centers horizontally */
      gap: 20px;
      flex-wrap: wrap; /* makes cards wrap on smaller screens */
    }

    .card {
      width: 280px;
      background-color: white;
      border: 2px solid black;
      border-radius: 15px;
      padding: 20px;
      box-shadow: 0 4px 10px orange;
      text-align: center;
    }

    .card img {
      width: 100%;
      border-radius: 10px;
    }

    .card p {
      font-size: 16px;
      color: #555;
    }
  </style>
</head>

<body>

